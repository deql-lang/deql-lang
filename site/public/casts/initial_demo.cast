[0.006, "o", "\r\u001b[Kdeql> \u001b[91mCREATE\u001b[0m \u001b[96mDECISION\u001b[0m Hire\r\n\u001b[91mFOR\u001b[0m Employee\r\n\u001b[91mON\u001b[0m \u001b[96mCOMMAND\u001b[0m HireEmployee\r\n\u001b[96mEMIT\u001b[0m \u001b[91mAS\u001b[0m\r\n  \u001b[91mSELECT\u001b[0m \u001b[91mEVENT\u001b[0m EmployeeHired (\r\n    \u001b[91mname\u001b[0m  := :\u001b[91mname\u001b[0m,\r\n    grade := :grade\r\n  );\r\u001b[4C\u001b[?2026l"]
[0.809, "o", "\u001b[?2026h"]
[0.000, "o", "\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[Kdeql> \u001b[91mCREATE\u001b[0m \u001b[96mDECISION\u001b[0m Hire\r\n\u001b[91mFOR\u001b[0m Employee\r\n\u001b[91mON\u001b[0m \u001b[96mCOMMAND\u001b[0m HireEmployee\r\n\u001b[96mEMIT\u001b[0m \u001b[91mAS\u001b[0m\r\n  \u001b[91mSELECT\u001b[0m \u001b[91mEVENT\u001b[0m EmployeeHired (\r\n    \u001b[91mname\u001b[0m  := :\u001b[91mname\u001b[0m,\r\n    grade := :grade\r\n  );\r\u001b[4C\u001b[?2026l"]
