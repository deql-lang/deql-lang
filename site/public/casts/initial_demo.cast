[7.494, "o", "\u001b[?2026h"]
[0.000, "o", "\r\u001b[Kdeql> \u001b[92m/* An employee should only be promoted when the new grade is different from their current grade. */\u001b[0m\r\n\r\u001b[?2026l"]
[9.730, "o", "\u001b[?2026h"]
[0.001, "o", "\r\u001b[K\u001b[A\r\u001b[Kdeql> \u001b[92m/* An employee should only be promoted when the new grade is different from their current grade. */\u001b[0m\r\n\u001b[91mCREATE\u001b[0m \u001b[96mDECISION\u001b[0m Promote\r\n\u001b[91mFOR\u001b[0m Employee\r\n\u001b[91mON\u001b[0m \u001b[96mCOMMAND\u001b[0m PromoteEmployee\r\nSTATE \u001b[91mAS\u001b[0m\r\n  \u001b[91mSELECT\u001b[0m\r\n    \u001b[91mLAST\u001b[0m(\r\n      \u001b[91mCASE\u001b[0m\r\n        \u001b[91mWHEN\u001b[0m event_type = \u001b[92m'EmployeeHired'\u001b[0m     \u001b[91mTHEN\u001b[0m \u001b[91mdata\u001b[0m.grade\r\n        \u001b[91mWHEN\u001b[0m event_type = \u001b[92m'EmployeePromoted'\u001b[0m \u001b[91mTHEN\u001b[0m \u001b[91mdata\u001b[0m.new_grade\r\n        \u001b[91mELSE\u001b[0m \u001b[91mNULL\u001b[0m\r\n      \u001b[91mEND\u001b[0m\r\n    ) \u001b[91mAS\u001b[0m current_grade\r\n  \u001b[91mFROM\u001b[0m \u001b[96mDeReg\u001b[0m.\u001b[96m\"Employee$Events\"\u001b[0m\r\n  \u001b[91mWHERE\u001b[0m stream_id = :employee_id\r\n\u001b[96mEMIT\u001b[0m \u001b[91mAS\u001b[0m\r\n  \u001b[91mSELECT\u001b[0m \u001b[91mEVENT\u001b[0m EmployeePromoted (\r\n    new_grade := :new_grade\r\n  )\r\n  \u001b[91mWHERE\u001b[0m :new_grade <> current_grade;\r\u001b[36C\u001b[?2026l"]
[12.354, "o", "\u001b[?2026h"]
[0.001, "o", "\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[K\u001b[A\r\u001b[Kdeql> \u001b[92m/* An employee should only be promoted when the new grade is different from their current grade. */\u001b[0m\r\n\u001b[91mCREATE\u001b[0m \u001b[96mDECISION\u001b[0m Promote\r\n\u001b[91mFOR\u001b[0m Employee\r\n\u001b[91mON\u001b[0m \u001b[96mCOMMAND\u001b[0m PromoteEmployee\r\nSTATE \u001b[91mAS\u001b[0m\r\n  \u001b[91mSELECT\u001b[0m\r\n    \u001b[91mLAST\u001b[0m(\r\n      \u001b[91mCASE\u001b[0m\r\n        \u001b[91mWHEN\u001b[0m event_type = \u001b[92m'EmployeeHired'\u001b[0m     \u001b[91mTHEN\u001b[0m \u001b[91mdata\u001b[0m.grade\r\n        \u001b[91mWHEN\u001b[0m event_type = \u001b[92m'EmployeePromoted'\u001b[0m \u001b[91mTHEN\u001b[0m \u001b[91mdata\u001b[0m.new_grade\r\n        \u001b[91mELSE\u001b[0m \u001b[91mNULL\u001b[0m\r\n      \u001b[91mEND\u001b[0m\r\n    ) \u001b[91mAS\u001b[0m current_grade\r\n  \u001b[91mFROM\u001b[0m \u001b[96mDeReg\u001b[0m.\u001b[96m\"Employee$Events\"\u001b[0m\r\n  \u001b[91mWHERE\u001b[0m stream_id = :employee_id\r\n\u001b[96mEMIT\u001b[0m \u001b[91mAS\u001b[0m\r\n  \u001b[91mSELECT\u001b[0m \u001b[91mEVENT\u001b[0m EmployeePromoted (\r\n    new_grade := :new_grade\r\n  )\r\n  \u001b[91mWHERE\u001b[0m :new_grade <> current_grade;\r\u001b[36C\u001b[?2026l"]
[0.001, "o", "\u001b[?2004l\r\n"]
